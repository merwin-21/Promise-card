<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Your Promise Verse | Department Fellowship 2026</title>
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,600;1,400&family=Inter:wght@300;400;500&display=swap" rel="stylesheet">
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        body {
            font-family: 'Inter', sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            padding: 20px;
            overflow-x: hidden;
        }
        .container {
            width: 100%;
            max-width: 460px;
            position: relative;
        }
        .card {
            background: white;
            border-radius: 24px;
            padding: 40px 30px;
            box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
            position: relative;
            overflow: hidden;
            animation: cardEntry 0.6s ease-out;
        }
        @keyframes cardEntry {
            from { opacity: 0; transform: translateY(30px) scale(0.95); }
            to { opacity: 1; transform: translateY(0) scale(1); }
        }
        .card::before {
            content: '';
            position: absolute;
            top: 0;
            left: 0;
            right: 0;
            height: 5px;
            background: linear-gradient(90deg, #f093fb 0%, #f5576c 50%, #4facfe 100%);
        }
        .header {
            text-align: center;
            margin-bottom: 30px;
        }
        .logo-icon {
            width: 64px;
            height: 64px;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0 auto 15px;
            font-size: 32px;
            color: white;
            box-shadow: 0 4px 15px rgba(102, 126, 234, 0.3);
        }
        .header h1 {
            font-family: 'Playfair Display', serif;
            font-size: 1.85rem;
            color: #1a1a2e;
            margin-bottom: 6px;
            font-weight: 600;
        }
        .header p {
            color: #666;
            font-size: 0.95rem;
            font-weight: 300;
        }
        .verse-container {
            background: linear-gradient(135deg, #f8fafc 0%, #e2e8f0 100%);
            border-radius: 20px;
            padding: 32px 28px;
            margin-bottom: 25px;
            position: relative;
            border-left: 5px solid #667eea;
        }
        .quote-icon {
            font-size: 3.5rem;
            color: #667eea;
            opacity: 0.15;
            position: absolute;
            top: 15px;
            left: 20px;
            font-family: Georgia, serif;
            line-height: 1;
        }
        .verse-text {
            font-family: 'Playfair Display', serif;
            font-size: 1.28rem;
            line-height: 1.65;
            color: #2d3748;
            text-align: center;
            position: relative;
            z-index: 1;
            font-style: italic;
            margin-bottom: 18px;
        }
        .verse-reference {
            text-align: center;
            color: #667eea;
            font-weight: 600;
            font-size: 0.98rem;
            text-transform: uppercase;
            letter-spacing: 1.2px;
        }
        .meta-info {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 25px;
            padding: 0 8px;
        }
        .draw-number {
            background: #edf2f7;
            padding: 8px 18px;
            border-radius: 30px;
            font-size: 0.87rem;
            color: #4a5568;
            font-weight: 500;
        }
        .timestamp {
            font-size: 0.82rem;
            color: #718096;
        }
        .actions {
            display: flex;
            gap: 12px;
            margin-bottom: 20px;
        }
        .btn {
            flex: 1;
            padding: 15px 20px;
            border: none;
            border-radius: 12px;
            font-size: 0.98rem;
            font-weight: 500;
            cursor: pointer;
            transition: all 0.3s ease;
            display: flex;
            align-items: center;
            justify-content: center;
            gap: 8px;
        }
        .btn-primary {
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            color: white;
        }
        .btn-primary:hover {
            transform: translateY(-2px);
            box-shadow: 0 12px 25px -5px rgba(102, 126, 234, 0.45);
        }
        .btn-secondary {
            background: #edf2f7;
            color: #4a5568;
        }
        .btn-secondary:hover {
            background: #e2e8f0;
        }
        .history-section {
            margin-top: 25px;
            padding-top: 25px;
            border-top: 1px solid #e2e8f0;
        }
        .history-title {
            font-size: 0.92rem;
            color: #4a5568;
            margin-bottom: 15px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .history-list {
            max-height: 210px;
            overflow-y: auto;
        }
        .history-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 12px 0;
            border-bottom: 1px solid #f1f5f9;
            font-size: 0.87rem;
        }
        .history-item:last-child {
            border-bottom: none;
        }
        .history-verse {
            color: #2d3748;
            font-weight: 500;
        }
        .history-time {
            color: #a0aec0;
            font-size: 0.78rem;
        }
        .stats {
            background: #f8fafc;
            border-radius: 12px;
            padding: 16px;
            margin-top: 20px;
            text-align: center;
            font-size: 0.88rem;
            color: #4a5568;
        }
        .stats strong {
            color: #667eea;
        }
        .loading {
            display: none;
            text-align: center;
            padding: 50px 20px;
        }
        .spinner {
            width: 42px;
            height: 42px;
            border: 4px solid #e2e8f0;
            border-top-color: #667eea;
            border-radius: 50%;
            animation: spin 1s linear infinite;
            margin: 0 auto 18px;
        }
        @keyframes spin {
            to { transform: rotate(360deg); }
        }
        .confetti {
            position: fixed;
            width: 10px;
            height: 10px;
            border-radius: 2px;
            z-index: 9999;
            animation: confetti-fall 3.5s ease-out forwards;
        }
        @keyframes confetti-fall {
            0% { transform: translateY(-150px) rotate(0deg); opacity: 1; }
            100% { transform: translateY(600px) rotate(720deg); opacity: 0; }
        }
        .toast {
            position: fixed;
            bottom: 30px;
            left: 50%;
            transform: translateX(-50%) translateY(100px);
            background: #1f2937;
            color: white;
            padding: 14px 26px;
            border-radius: 10px;
            font-size: 0.95rem;
            opacity: 0;
            transition: all 0.4s ease;
            z-index: 10000;
            box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.2);
        }
        .toast.show {
            transform: translateX(-50%) translateY(0);
            opacity: 1;
        }

        @media (max-width: 480px) {
            .card {
                padding: 32px 22px;
            }
            .verse-text {
                font-size: 1.15rem;
            }
        }
    </style>
</head>
<body>
    <div class="container">
        <div class="card" id="mainCard">
            <div class="header">
                <div class="logo-icon">✝</div>
                <h1>Your Promise Verse</h1>
                <p>Department Fellowship 2026</p>
            </div>

            <div class="loading" id="loading">
                <div class="spinner"></div>
                <p style="color: #666; font-size: 0.95rem;">Receiving your promise...</p>
            </div>

            <div id="content" style="display: none;">
                <div class="verse-container">
                    <div class="quote-icon">“</div>
                    <div class="verse-text" id="verseText"></div>
                    <div class="verse-reference" id="verseRef"></div>
                </div>

                <div class="meta-info">
                    <span class="draw-number" id="drawNumber">Draw #1</span>
                    <span class="timestamp" id="timestamp"></span>
                </div>

                <div class="actions">
                    <button class="btn btn-primary" onclick="drawNewVerse()">
                        <span>🎲</span> New Verse
                    </button>
                    <button class="btn btn-secondary" onclick="shareVerse()">
                        <span>📤</span> Share
                    </button>
                </div>

                <div class="stats" id="stats">
                    <strong id="uniqueCount">0</strong> unique verses drawn so far
                </div>

                <div class="history-section" id="historySection" style="display: none;">
                    <div class="history-title">
                        <span>📜</span> Your Previous Verses
                    </div>
                    <div class="history-list" id="historyList"></div>
                </div>
            </div>
        </div>
    </div>

    <div class="toast" id="toast"></div>

    <script>
        // Cleaned and deduplicated Promise Verses (High Quality)
        const promiseVerses = [
            { text: "For I know the plans I have for you, declares the Lord, plans to prosper you and not to harm you, plans to give you hope and a future.", reference: "Jeremiah 29:11" },
            { text: "I can do all things through Christ who strengthens me.", reference: "Philippians 4:13" },
            { text: "The Lord is my shepherd; I shall not want.", reference: "Psalm 23:1" },
            { text: "For God so loved the world that he gave his one and only Son, that whoever believes in him shall not perish but have eternal life.", reference: "John 3:16" },
            { text: "The Lord is my light and my salvation—whom shall I fear?", reference: "Psalm 27:1" },
            { text: "And we know that in all things God works for the good of those who love him, who have been called according to his purpose.", reference: "Romans 8:28" },
            { text: "But seek first his kingdom and his righteousness, and all these things will be given to you as well.", reference: "Matthew 6:33" },
            { text: "Have I not commanded you? Be strong and courageous. Do not be afraid; do not be discouraged, for the Lord your God will be with you wherever you go.", reference: "Joshua 1:9" },
            { text: "Cast all your anxiety on him because he cares for you.", reference: "1 Peter 5:7" },
            { text: "The Lord will fight for you; you need only to be still.", reference: "Exodus 14:14" },
            { text: "Come to me, all you who are weary and burdened, and I will give you rest.", reference: "Matthew 11:28" },
            { text: "Trust in the Lord with all your heart and lean not on your own understanding.", reference: "Proverbs 3:5" },
            { text: "But those who hope in the Lord will renew their strength. They will soar on wings like eagles.", reference: "Isaiah 40:31" },
            { text: "The Lord is close to the brokenhearted and saves those who are crushed in spirit.", reference: "Psalm 34:18" },
            { text: "If God is for us, who can be against us?", reference: "Romans 8:31" },
            { text: "I will never leave you nor forsake you.", reference: "Hebrews 13:5" },
            { text: "The joy of the Lord is your strength.", reference: "Nehemiah 8:10" },
            { text: "For the Spirit God gave us does not make us timid, but gives us power, love and self-discipline.", reference: "2 Timothy 1:7" },
            { text: "My grace is sufficient for you, for my power is made perfect in weakness.", reference: "2 Corinthians 12:9" },
            { text: "You will keep in perfect peace those whose minds are steadfast, because they trust in you.", reference: "Isaiah 26:3" },
            { text: "The Lord your God is with you, the Mighty Warrior who saves. He will take great delight in you.", reference: "Zephaniah 3:17" },
            { text: "He gives strength to the weary and increases the power of the weak.", reference: "Isaiah 40:29" },
            { text: "Your word is a lamp for my feet, a light on my path.", reference: "Psalm 119:105" },
            { text: "Even though I walk through the darkest valley, I will fear no evil, for you are with me.", reference: "Psalm 23:4" },
            { text: "Do not be anxious about anything, but in every situation, by prayer and petition, with thanksgiving, present your requests to God.", reference: "Philippians 4:6" },
            { text: "And the peace of God, which transcends all understanding, will guard your hearts and your minds in Christ Jesus.", reference: "Philippians 4:7" },
            { text: "He heals the brokenhearted and binds up their wounds.", reference: "Psalm 147:3" },
            { text: "He will cover you with his feathers, and under his wings you will find refuge.", reference: "Psalm 91:4" },
            { text: "Taste and see that the Lord is good; blessed is the one who takes refuge in him.", reference: "Psalm 34:8" },
            { text: "The Lord is my rock, my fortress and my deliverer; my God is my rock, in whom I take refuge.", reference: "Psalm 18:2" }
        ];

        let currentVerse = null;
        let drawHistory = JSON.parse(localStorage.getItem('promiseDraws') || '[]');
        let globalDrawCount = parseInt(localStorage.getItem('globalDrawCount') || '0');

        // Initialize
        window.onload = function() {
            setTimeout(() => {
                document.getElementById('loading').style.display = 'none';
                document.getElementById('content').style.display = 'block';
                drawNewVerse();
            }, 1200);
        };

        function getRandomVerse() {
            let availableVerses = promiseVerses.filter(v => 
                !drawHistory.some(h => h.reference === v.reference)
            );

            // Reset history if all verses have been used
            if (availableVerses.length === 0) {
                drawHistory = [];
                localStorage.setItem('promiseDraws', '[]');
                availableVerses = [...promiseVerses];
            }

            return availableVerses[Math.floor(Math.random() * availableVerses.length)];
        }

        function drawNewVerse() {
            currentVerse = getRandomVerse();
            globalDrawCount++;

            // Update UI
            document.getElementById('verseText').textContent = currentVerse.text;
            document.getElementById('verseRef').textContent = currentVerse.reference;
            document.getElementById('drawNumber').textContent = `Draw #${globalDrawCount}`;
            document.getElementById('timestamp').textContent = new Date().toLocaleString('en-IN');
            document.getElementById('uniqueCount').textContent = globalDrawCount;

            // Save to history
            const drawRecord = {
                ...currentVerse,
                timestamp: new Date().toISOString(),
                drawNumber: globalDrawCount
            };

            drawHistory.unshift(drawRecord);
            localStorage.setItem('promiseDraws', JSON.stringify(drawHistory));
            localStorage.setItem('globalDrawCount', globalDrawCount.toString());

            updateHistory();
            createConfetti();
        }

        function updateHistory() {
            const historySection = document.getElementById('historySection');
            const historyList = document.getElementById('historyList');

            if (drawHistory.length > 1) {
                historySection.style.display = 'block';
                historyList.innerHTML = drawHistory.slice(1).map(h => `
                    <div class="history-item">
                        <span class="history-verse">${h.reference}</span>
                        <span class="history-time">${new Date(h.timestamp).toLocaleTimeString('en-IN')}</span>
                    </div>
                `).join('');
            } else {
                historySection.style.display = 'none';
            }
        }

        function shareVerse() {
            if (!currentVerse) return;

            const shareText = `"${currentVerse.text}" — ${currentVerse.reference}\n\nDepartment Fellowship 2026`;

            if (navigator.share) {
                navigator.share({
                    title: 'My Promise Verse',
                    text: shareText,
                    url: window.location.href
                }).catch(() => {});
            } else {
                navigator.clipboard.writeText(shareText).then(() => {
                    showToast('Verse copied to clipboard!');
                }).catch(() => {
                    showToast('Failed to copy verse');
                });
            }
        }

        function showToast(message) {
            const toast = document.getElementById('toast');
            toast.textContent = message;
            toast.classList.add('show');
            setTimeout(() => toast.classList.remove('show'), 2800);
        }

        function createConfetti() {
            const colors = ['#f5576c', '#4facfe', '#667eea', '#f093fb', '#43e97b', '#ffd93d'];
            for (let i = 0; i < 25; i++) {
                setTimeout(() => {
                    const confetti = document.createElement('div');
                    confetti.className = 'confetti';
                    confetti.style.left = Math.random() * 100 + '%';
                    confetti.style.background = colors[Math.floor(Math.random() * colors.length)];
                    confetti.style.width = Math.random() * 8 + 6 + 'px';
                    confetti.style.height = confetti.style.width;
                    confetti.style.animationDuration = (Math.random() * 2 + 2.5) + 's';
                    confetti.style.opacity = Math.random() * 0.8 + 0.6;
                    document.body.appendChild(confetti);

                    setTimeout(() => confetti.remove(), 4500);
                }, i * 35);
            }
        }
    </script>
</body>
</html>
